# ============================================
# SISTEMA SOLARES - .gitignore raíz
# ============================================

# --- Archivos de base de datos ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- Build artifacts (recursivo) ---
**/build/
**/dist/
**/.dart_tool/
**/node_modules/

# --- Backups ---
backups/
backups_audit/

# --- Instaladores y binarios ---
*.apk
*.aab
*.exe
*.msi
*.zip
*.7z
*.rar
*.tar.gz
*.tar

# --- IDE / Editor ---
.idea/
*.iml
*.ipr
*.iws
.vscode/

# --- Logs y temporales ---
*.log
*.tmp
*.temp
*.swp
*.class
*.pyc
.DS_Store
.history

# --- Flutter/Dart ---
**/doc/api/
**/ios/Flutter/.last_build_id
.flutter-plugins-dependencies
.pub-cache/
.pub/
/coverage/
.dart_tool/

# --- Symbolication ---
app.*.symbols
app.*.map.json

# --- Android Studio ---
/android/app/debug
/android/app/profile
/android/app/release

# --- Otros ---
.atom/
.build/
.buildlog/
.svn/
.swiftpm/
migrate_working_dir/

# --- Probes (datos simulados de entorno limpio) ---
tools/probes/

# --- Output de scripts ---
tools/scripts/probe_output_new.json

# --- Docs misceláneos (capturas, dumps) ---
docs/misc/
docs/logs/

# --- Distribuciones / releases locales ---
dist_release/

# --- Archivo de entorno ---
.env
