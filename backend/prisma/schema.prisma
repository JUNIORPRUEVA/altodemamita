generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  TECH
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id         String        @id @default(uuid())
  tenantKey String        @unique
  name       String
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  clients      Client[]
  sellers      Seller[]
  lots         Lot[]
  sales        Sale[]
  installments Installment[]
  payments     Payment[]
  syncBatches  SyncBatch[]
}

model Client {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  syncId    String
  name      String
  document  String?
  phone     String?
  address   String?
  raw        Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model Seller {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  syncId    String
  name      String
  document  String?
  phone     String?
  active    Boolean  @default(true)
  raw       Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model Lot {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  syncId    String
  block     String?
  number    String?
  status    String?
  area      Decimal? @db.Decimal(14, 2)
  price     Decimal? @db.Decimal(14, 2)
  raw       Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model Sale {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  syncId       String
  clientSyncId String?
  lotSyncId    String?
  sellerSyncId String?
  saleDate     DateTime?
  status       String?
  total        Decimal  @default(0) @db.Decimal(14, 2)
  initialPaid  Decimal  @default(0) @db.Decimal(14, 2)
  balance      Decimal  @default(0) @db.Decimal(14, 2)
  raw          Json?
  version      Int      @default(1)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model Installment {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  syncId              String
  saleSyncId          String?
  installmentNumber   Int?
  dueDate             DateTime?
  openingBalance      Decimal  @default(0) @db.Decimal(14, 2)
  principalAmount     Decimal  @default(0) @db.Decimal(14, 2)
  interestAmount      Decimal  @default(0) @db.Decimal(14, 2)
  totalAmount         Decimal  @default(0) @db.Decimal(14, 2)
  paidAmount          Decimal  @default(0) @db.Decimal(14, 2)
  paidPrincipalAmount Decimal  @default(0) @db.Decimal(14, 2)
  paidInterestAmount  Decimal  @default(0) @db.Decimal(14, 2)
  endingBalance       Decimal  @default(0) @db.Decimal(14, 2)
  status              String?
  raw                 Json?
  version             Int      @default(1)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model Payment {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  syncId            String
  saleSyncId        String?
  clientSyncId      String?
  installmentSyncId String?
  paidAt            DateTime?
  amount            Decimal  @default(0) @db.Decimal(14, 2)
  method            String?
  paymentType       String?
  reference         String?
  yearToPay         Int?
  raw               Json?
  version           Int      @default(1)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, syncId])
  @@index([companyId, updatedAt])
}

model SyncBatch {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  deviceId      String
  receivedCounts Json
  appliedCounts  Json
  createdAt      DateTime @default(now())

  @@index([companyId, createdAt])
}
