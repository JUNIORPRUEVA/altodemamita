generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  TECH
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String   @id @default(uuid())
  syncId    String   @unique
  name      String
  document  String?
  phone     String?
  address   String?
  raw        Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seller {
  id        String   @id @default(uuid())
  syncId    String   @unique
  name      String
  document  String?
  phone     String?
  active    Boolean  @default(true)
  raw       Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lot {
  id        String   @id @default(uuid())
  syncId    String   @unique
  block     String?
  number    String?
  status    String?
  area      Decimal? @db.Decimal(14, 2)
  price     Decimal? @db.Decimal(14, 2)
  raw       Json?
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id           String   @id @default(uuid())
  syncId       String   @unique
  clientSyncId String?
  lotSyncId    String?
  sellerSyncId String?
  saleDate     DateTime?
  status       String?
  total        Decimal  @default(0) @db.Decimal(14, 2)
  initialPaid  Decimal  @default(0) @db.Decimal(14, 2)
  balance      Decimal  @default(0) @db.Decimal(14, 2)
  raw          Json?
  version      Int      @default(1)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Installment {
  id                  String   @id @default(uuid())
  syncId              String   @unique
  saleSyncId          String?
  installmentNumber   Int?
  dueDate             DateTime?
  openingBalance      Decimal  @default(0) @db.Decimal(14, 2)
  principalAmount     Decimal  @default(0) @db.Decimal(14, 2)
  interestAmount      Decimal  @default(0) @db.Decimal(14, 2)
  totalAmount         Decimal  @default(0) @db.Decimal(14, 2)
  paidAmount          Decimal  @default(0) @db.Decimal(14, 2)
  paidPrincipalAmount Decimal  @default(0) @db.Decimal(14, 2)
  paidInterestAmount  Decimal  @default(0) @db.Decimal(14, 2)
  endingBalance       Decimal  @default(0) @db.Decimal(14, 2)
  status              String?
  raw                 Json?
  version             Int      @default(1)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id                String   @id @default(uuid())
  syncId            String   @unique
  saleSyncId        String?
  clientSyncId      String?
  installmentSyncId String?
  paidAt            DateTime?
  amount            Decimal  @default(0) @db.Decimal(14, 2)
  method            String?
  paymentType       String?
  reference         String?
  yearToPay         Int?
  raw               Json?
  version           Int      @default(1)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SyncBatch {
  id            String   @id @default(uuid())
  deviceId      String
  receivedCounts Json
  appliedCounts  Json
  createdAt      DateTime @default(now())
}
