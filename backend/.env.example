NODE_ENV=development
PORT=3000
API_PREFIX=api

# Opcion 1: URL completa de PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sistema_solares_backend?schema=public

# Opcion 2: Variables discretas para EasyPanel / Docker
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sistema_solares_backend
DB_SCHEMA=public

JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1d
APP_NAME=Sistema Solares Backend
PANEL_WEB_ORIGIN=http://localhost:8080
PANEL_WEB_ORIGINS=http://localhost:8080,https://altodemamita.com,https://www.altodemamita.com
READ_ONLY_MODE=false
# Modo LOCAL MASTER: la PC primaria autorizada siempre gana conflictos de timestamp en scopes comerciales
LOCAL_MASTER_MODE=false
