{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter Windows Setup (Hot Reload)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", ".\\tool\\flutter_vscode_setup.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter Run Windows",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\tool\\flutter_windows_dev.ps1"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Flutter Run Windows Verbose",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\tool\\flutter_windows_dev.ps1",
        "run",
        "-d",
        "windows",
        "-v"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Flutter Test Windows Safe",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\tool\\flutter_windows_dev.ps1",
        "test"
      ],
      "problemMatcher": []
    }
  ]
}